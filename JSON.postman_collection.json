      "name": "LISTING ALL RESOURCES",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Request-level tests: LISTING ALL RESOURCES (GET)",
              "",
              "pm.test(\"Status code is 200 OK\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is a JSON array\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(Array.isArray(json)).to.equal(true);",
              "});",
              "",
              "pm.test(\"Array items have basic post fields (spot-check first item if present)\", function () {",
              "  const json = pm.response.json();",
              "  if (!Array.isArray(json) || json.length === 0) return;",
              "",
              "  const first = json[0];",
              "  pm.expect(first).to.be.an(\"object\");",
              "  pm.expect(first).to.have.property(\"id\");",
              "  pm.expect(first).to.have.property(\"title\");",
              "  pm.expect(first).to.have.property(\"body\");",
              "  pm.expect(first).to.have.property(\"userId\");",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
