            "exec": [
              "// Request-level tests: UPDATING A RESOURCE (PUT /posts/1)",
              "",
              "pm.test(\"Status code is 200 OK\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response includes required fields (id, title, body, userId)\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property(\"id\");",
              "  pm.expect(json).to.have.property(\"title\");",
              "  pm.expect(json).to.have.property(\"body\");",
              "  pm.expect(json).to.have.property(\"userId\");",
              "});",
              "",
              "pm.test(\"Response id matches the path id (resilient)\", function () {",
              "  const json = pm.response.json();",
              "",
              "  const pathSegments = pm.request.url.path || [];",
              "  const last = pathSegments[pathSegments.length - 1];",
              "  const expectedId = Number(last);",
              "",
              "  if (!Number.isNaN(expectedId)) {",
              "    pm.expect(json.id).to.eql(expectedId);",
              "  }",
              "});",
              "",
              "pm.test(\"Response echoes request body fields when appropriate\", function () {",
              "  const res = pm.response.json();",
              "",
              "  let reqBody = {};",
              "  try {",
              "    reqBody = pm.request.body && pm.request.body.raw ? JSON.parse(pm.request.body.raw) : {};",
              "  } catch (e) {",
              "    reqBody = {};",
              "  }",
              "",
              "  if (Object.prototype.hasOwnProperty.call(reqBody, \"title\")) {",
              "    pm.expect(res.title).to.eql(reqBody.title);",
              "  }",
              "  if (Object.prototype.hasOwnProperty.call(reqBody, \"body\")) {",
              "    pm.expect(res.body).to.eql(reqBody.body);",
              "  }",
              "  if (Object.prototype.hasOwnProperty.call(reqBody, \"userId\")) {",
              "    pm.expect(res.userId).to.eql(reqBody.userId);",
              "  }",
              "});",
              ""
