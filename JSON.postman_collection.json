              "",
              "pm.test('Response is a JSON object with an id', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(Array.isArray(json)).to.equal(false);",
              "    pm.expect(json).to.be.an('object');",
              "    pm.expect(json).to.have.property('id');",
              "})",
              "",
              "pm.test('Response includes basic post fields', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('title');",
              "    pm.expect(json).to.have.property('body');",
              "    pm.expect(json).to.have.property('userId');",
              "})",
              "",
              "pm.test('Response echoes request body fields when appropriate', function () {",
              "    const res = pm.response.json();",
              "    let reqBody = {};",
              "    try {",
              "        reqBody = pm.request.body && pm.request.body.raw ? JSON.parse(pm.request.body.raw) : {};",
              "    } catch (e) {",
              "        reqBody = {};",
              "    }",
              "    [",
              "        'title',",
              "        'body',",
              "        'userId'",
              "    ].forEach(function (k) {",
              "        if (Object.prototype.hasOwnProperty.call(reqBody, k)) {",
              "            pm.expect(res).to.have.property(k);",
              "            pm.expect(res[k]).to.eql(reqBody[k]);",
              "        }",
              "    });",
              "})"
