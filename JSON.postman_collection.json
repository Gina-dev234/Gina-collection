          "script": {
            "type": "text/javascript",
            "exec": [
              "// Request-level tests: PATCHING A RESOURCE (PATCH /posts/1)",
              "",
              "pm.test(\"Status code is 200 OK\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is a JSON object\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(Array.isArray(json)).to.equal(false);",
              "  pm.expect(typeof json).to.equal(\"object\");",
              "});",
              "",
              "pm.test(\"Response contains id matching the path id (resilient)\", function () {",
              "  const json = pm.response.json();",
              "",
              "  const pathSegments = pm.request.url.path || [];",
              "  const last = pathSegments[pathSegments.length - 1];",
              "  const expectedId = Number(last);",
              "",
              "  if (!Number.isNaN(expectedId)) {",
              "    pm.expect(json).to.have.property(\"id\");",
              "    pm.expect(json.id).to.eql(expectedId);",
              "  }",
              "});",
              "",
              "pm.test(\"Response includes patched fields and echoes values when appropriate\", function () {",
              "  const res = pm.response.json();",
              "",
              "  let reqBody = {};",
              "  try {",
              "    reqBody = pm.request.body && pm.request.body.raw ? JSON.parse(pm.request.body.raw) : {};",
              "  } catch (e) {",
              "    reqBody = {};",
              "  }",
              "",
              "  // Only check keys that are present in the PATCH payload",
              "  Object.keys(reqBody || {}).forEach(function (k) {",
              "    pm.expect(res).to.have.property(k);",
              "    pm.expect(res[k]).to.eql(reqBody[k]);",
              "  });",
              "});",
              ""
            ]
          }
        }
