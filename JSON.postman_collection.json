    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "requests": {},
        "exec": [
          "// Collection-level tests for JSONPlaceholder (jsonplaceholder.typicode.com)",
          "// Applies broadly across requests in this collection. Request-level tests handle endpoint-specific assertions.",
          "",
          "// --- Performance ---",
          "pm.test(\"Response time is under 2000ms\", function () {",
          "  pm.expect(pm.response.responseTime).to.be.below(2000);",
          "});",
          "",
          "// --- Status code sanity ---",
          "pm.test(\"Status code is a valid success/expected code\", function () {",
          "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]);",
          "});",
          "",
          "// --- Content-Type for responses with body ---",
          "pm.test(\"Response Content-Type is JSON when body is present\", function () {",
          "  // Some endpoints may return 204 with no content",
          "  if (pm.response.code === 204) return;",
          "",
          "  const contentType = pm.response.headers.get(\"Content-Type\") || \"\";",
          "  pm.expect(contentType.toLowerCase()).to.include(\"application/json\");",
          "});",
          "",
          "// --- JSON parse + basic shape checks ---",
          "pm.test(\"Response body is valid JSON when body is present\", function () {",
          "  if (pm.response.code === 204) return;",
          "  pm.response.to.be.json;",
          "});",
          "",
          "pm.test(\"Response JSON has an expected basic shape (object/array) when body is present\", function () {",
          "  if (pm.response.code === 204) return;",
          "",
          "  const data = pm.response.json();",
          "  pm.expect(data === null).to.equal(false);",
          "  pm.expect(Array.isArray(data) || typeof data === \"object\").to.equal(true);",
          "});",
          "",
          "// --- Common fields for /posts responses ---",
          "pm.test(\"/posts responses include expected fields when response is an object\", function () {",
          "  if (pm.response.code === 204) return;",
          "",
          "  const reqUrl = (pm.request.url && pm.request.url.toString()) || \"\";",
          "  const isPostsEndpoint = reqUrl.includes(\"jsonplaceholder.typicode.com/posts\");",
          "  if (!isPostsEndpoint) return;",
          "",
          "  const json = pm.response.json();",
          "  if (Array.isArray(json)) return;",
          "",
          "  pm.expect(json).to.have.property(\"userId\");",
          "  pm.expect(json).to.have.property(\"title\");",
          "  pm.expect(json).to.have.property(\"body\");",
          "",
          "  // id is typically present for posts resources but avoid hard-coding values",
          "  pm.expect(json).to.have.property(\"id\");",
          "});",
          ""
        ]
      }
