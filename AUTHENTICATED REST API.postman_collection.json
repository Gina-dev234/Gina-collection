              "})",
              "",
              "pm.test('Create: returned fields reflect sent body when possible', function () {",
              "    const ct = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
              "    if (!ct.includes('application/json'))",
              "        return;",
              "    let sent;",
              "    try {",
              "        sent = pm.request.body && pm.request.body.raw ? JSON.parse(pm.request.body.raw) : null;",
              "    } catch (e) {",
              "        sent = null;",
              "    }",
              "    if (!sent)",
              "        return;",
              "    const json = pm.response.json();",
              "    [",
              "        'name',",
              "        'data',",
              "        'title',",
              "        'body'",
              "    ].forEach(k => {",
              "        if (Object.prototype.hasOwnProperty.call(sent, k) && Object.prototype.hasOwnProperty.call(json, k)) {",
              "            pm.expect(json[k], `Field '${ k }' should match request`).to.eql(sent[k]);",
              "        }",
              "    });",
              "})"
            ]
          }
        }
