  "item": [
    {
      "name": "CREATE AN ITEM",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Response is an array or object (list-like)', function () {",
              "    const ct = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
              "    if (!ct.includes('application/json'))",
              "        return;",
              "    const data = pm.response.json();",
              "    pm.expect(data, 'Expected array or object').to.satisfy(v => Array.isArray(v) || v && typeof v === 'object');",
              "})",
              "",
              "pm.test('List endpoint: array items have an id when array is returned', function () {",
              "    const ct = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
              "    if (!ct.includes('application/json'))",
              "        return;",
              "    const data = pm.response.json();",
              "    if (!Array.isArray(data))",
              "        return;",
              "    data.forEach((item, idx) => {",
              "        pm.expect(item, `Item at index ${ idx } should be an object`).to.be.an('object');",
              "        pm.expect(item).to.have.property('id');",
              "    });",
              "})"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/objects",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "objects"
          ]
        }
