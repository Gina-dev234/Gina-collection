              "    const url = pm.request.url.toString();",
              "    const match = url.match(/\\/([^\\/?#]+)\\/?(?:\\?|#|$)/);",
              "    if (!match)",
              "        return;",
              "    const expectedId = match[1];",
              "    pm.expect(String(json.id), 'Response id should match request path id').to.eql(String(expectedId));",
