  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection pre-request script: Initialize collection variables if not set",
          "if (!pm.collectionVariables.get(\"baseUrl\")) {",
          "    pm.collectionVariables.set(\"baseUrl\", \"https://api.restful-api.dev\");",
          "}",
          "if (!pm.collectionVariables.get(\"objectId\")) {",
          "    pm.collectionVariables.set(\"objectId\", \"ff8081819cd4022c019cf64bd6b8337e\");",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level API tests (apply to every request)",
          "// Best practices:",
          "// - Broad success-code validation (2xx/3xx) unless request indicates a negative test",
          "// - Response time threshold",
          "// - Auth header presence (when collection uses auth)",
          "// - JSON Content-Type and valid JSON when a body is present",
          "",
          "(function () {",
          "  const requestName = (pm.info.requestName || \"\").toLowerCase();",
          "  const isNegative = /(negative|invalid|unauthoriz|forbidden|not\\s*found|bad\\s*request|error)/i.test(requestName);",
          "",
          "  // --- Performance ---",
          "  pm.test(\"Response time is under 2000ms\", function () {",
          "    pm.expect(pm.response.responseTime, `Response time was ${pm.response.responseTime}ms`).to.be.below(2000);",
          "  });",
          "",
          "  // --- Status code range ---",
          "  pm.test(\"Status code is in expected range\", function () {",
          "    const code = pm.response.code;",
          "    if (isNegative) {",
          "      // Negative tests typically expect 4xx/5xx",
          "      pm.expect(code, `Unexpected status code for negative test: ${code}`).to.be.within(400, 599);",
          "    } else {",
          "      // Successful flows: allow 2xx and 3xx",
          "      pm.expect(code, `Unexpected status code: ${code}. Body (first 200 chars): ${(pm.response.text() || \"\").slice(0, 200)}`)",
          "        .to.be.within(200, 399);",
          "    }",
          "  });",
          "",
          "  // Helper: determine if response should have a body",
          "  function hasResponseBody() {",
          "    if ([204, 205, 304].includes(pm.response.code)) return false;",
          "    const method = (pm.request.method || \"\").toUpperCase();",
          "    if (method === \"HEAD\") return false;",
          "    const text = pm.response.text();",
          "    return typeof text === \"string\" && text.trim().length > 0;",
          "  }",
          "",
          "  // --- Auth header presence (do not reveal secret) ---",
          "  pm.test(\"Auth header exists when using API key auth\", function () {",
          "    // Collection auth uses x-api-key header. Validate it's present on the actual request.",
          "    // (Postman may inject it via auth helpers; this checks the final request headers.)",
          "    const key = \"x-api-key\";",
          "    const value = pm.request.headers.get(key);",
          "    pm.expect(!!value, `Missing required auth header: ${key}`).to.eql(true);",
          "    // Ensure it's not accidentally left as an empty string.",
          "    pm.expect((value || \"\").trim().length, `${key} header is empty`).to.be.greaterThan(0);",
          "  });",
          "",
          "  // --- JSON Content-Type & parseability (when applicable) ---",
          "  pm.test(\"Content-Type is JSON when a body is present\", function () {",
          "    if (!hasResponseBody()) return;",
          "    const ct = pm.response.headers.get(\"Content-Type\") || \"\";",
          "    pm.expect(ct.toLowerCase(), `Expected JSON Content-Type but got: '${ct}'`).to.include(\"application/json\");",
          "  });",
          "",
          "  pm.test(\"Response body is valid JSON when a body is present\", function () {",
          "    if (!hasResponseBody()) return;",
          "    const ct = (pm.response.headers.get(\"Content-Type\") || \"\").toLowerCase();",
          "    if (!ct.includes(\"application/json\")) return; // Only enforce JSON parsing for JSON responses",
          "",
          "    let parsed;",
          "    pm.expect(function () {",
          "      parsed = pm.response.json();",
          "    }, `Response was not valid JSON. Body preview: ${(pm.response.text() || \"\").slice(0, 200)}`).to.not.throw();",
          "",
          "    pm.expect(parsed, \"Parsed JSON should be an object or array\").to.satisfy(v => v !== null && (Array.isArray(v) || typeof v === \"object\"));",
          "  });",
          "})();"
        ]
      }
    }
  ]
