      "name": "LIST OF ITEM",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "})",
              "",
              "pm.test('Response time is < 2000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "})",
              "",
              "pm.test('Content-Type is JSON', function () {",
              "    pm.expect(pm.response.headers.get('Content-Type') || '').to.match(/application\\/json/i);",
              "})",
              "",
              "pm.test('Response body is an array', function () {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "})",
              "",
              "pm.test('Each item has id and name', function () {",
              "    const arr = pm.response.json();",
              "    arr.forEach(item => {",
              "        pm.expect(item).to.have.property('id');",
              "        pm.expect(item.id).to.not.be.oneOf([",
              "            null,",
              "            ''",
              "        ]);",
              "        pm.expect(item).to.have.property('name');",
              "        pm.expect(item.name).to.be.a('string');",
              "    });",
              "})"
            ]
          }
        }
      ],
