      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200 or 201', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([",
              "        200,",
              "        201",
              "    ]);",
              "})",
              "",
              "pm.test('Response time is < 2000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "})",
              "",
              "pm.test('Content-Type is JSON', function () {",
              "    pm.expect(pm.response.headers.get('Content-Type') || '').to.match(/application\\/json/i);",
              "})",
              "",
              "pm.test('Response has id/name/data', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json.id).to.not.be.oneOf([",
              "        null,",
              "        ''",
              "    ]);",
              "    pm.expect(json).to.have.property('name');",
              "    pm.expect(json.name).to.be.a('string');",
              "    pm.expect(json).to.have.property('data');",
              "    pm.expect(json.data).to.be.an('object');",
              "})",
              "",
              "pm.test('Store objectId for downstream requests', function () {",
              "    const json = pm.response.json();",
              "    pm.collectionVariables.set('objectId', String(json.id));",
              "    pm.expect(pm.collectionVariables.get('objectId'), 'objectId collection variable should be set').to.be.ok;",
              "})"
            ]
          }
        }
      ],
