    {
      "name": "DELETE ITEM",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Precondition: objectId is set', function () {",
              "    const objectId = pm.collectionVariables.get('objectId');",
              "    pm.expect(objectId, 'objectId collection variable is not set. Run CREATE AN ITEM first.').to.be.ok;",
              "})",
              "",
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "})",
              "",
              "pm.test('Response time is < 2000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "})",
              "",
              "pm.test('Content-Type is JSON when response has a body', function () {",
              "    const body = pm.response.text();",
              "    if (body && body.trim().length > 0) {",
              "        pm.expect(pm.response.headers.get('Content-Type') || '').to.match(/application\\/json/i);",
              "    } else {",
              "        pm.expect(true).to.eql(true);",
              "    }",
              "})",
              "",
              "pm.test('Delete response references the deleted objectId when applicable', function () {",
              "    const body = pm.response.text();",
              "    if (body && body.trim().length > 0) {",
              "        const json = pm.response.json();",
              "        const objectId = pm.collectionVariables.get('objectId');",
              "        if (json && typeof json === 'object' && 'id' in json) {",
              "            pm.expect(String(json.id)).to.eql(String(objectId));",
              "        } else {",
              "            pm.expect(true).to.eql(true);",
              "        }",
              "    } else {",
              "        pm.expect(true).to.eql(true);",
              "    }",
              "})",
              "",
              "pm.test('Clear objectId after delete', function () {",
              "    pm.collectionVariables.unset('objectId');",
              "    pm.expect(pm.collectionVariables.get('objectId')).to.not.be.ok;",
              "})"
            ]
          }
        }
      ],
