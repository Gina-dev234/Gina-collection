  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Validate and normalize collection variable: BASEURL",
          "// This runs before every request in the collection.",
          "(function () {",
          "  const varName = 'BASEURL';",
          "  const raw = pm.collectionVariables.get(varName);",
          "",
          "  // Treat undefined/null/non-string as missing, and blank/whitespace-only as empty",
          "  if (raw === undefined || raw === null || String(raw).trim() === '') {",
          "    throw new Error(",
          "      `[${pm.info.collectionName || 'Collection'}] Missing required collection variable \"${varName}\".\\n` +",
          "      `Set it via: Collection  Variables  ${varName} (e.g., https://api.restful-api.dev).`",
          "    );",
          "  }",
          "",
          "  // Normalize without changing semantics: trim whitespace and remove trailing slash(es)",
          "  const normalized = String(raw).trim().replace(/\\/+$/, '');",
          "",
          "  // Only overwrite if we have a non-empty normalized value",
          "  if (normalized !== '' && normalized !== raw) {",
          "    pm.collectionVariables.set(varName, normalized);",
          "  }",
          "})();",
          ""
        ]
      }
    },
